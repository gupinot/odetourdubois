---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title="Bienvenue" theme="dark">
  <div class="welcome">
    <div class="image-wrap">
      <img
        src={`${base}images/bienvenue/funambule.jpg`}
        alt="Roland Pinot — sculpteur sur bois"
        class="hero"
      />
    </div>
    <div class="branding">
      <img
        src={`${base}images/bienvenue/logo.png`}
        alt="Roland Pinot sculpteur sur bois"
        class="logo"
      />
    </div>
  </div>
</Layout>

<style>
  .welcome {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 2.5rem 0;
  }

  .image-wrap {
    flex: 1;
    min-height: 0;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero {
    display: block;
    height: 100%;
    max-height: 100%;
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }

  .branding {
    flex-shrink: 0;
    text-align: center;
  }

  .logo {
    max-width: 380px;
    width: 90%;
    height: auto;
    opacity: 0.9;
  }
</style>
