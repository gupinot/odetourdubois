---
import Layout from "../layouts/Layout.astro";
const base = import.meta.env.BASE_URL;
---

<Layout title="Salle exposition" theme="dark">
  <div class="page-content">
    <div class="image-wrap">
      <img
        src={`${base}images/pages/salle_expo.jpg`}
        alt="Salle d'exposition Roland Pinot"
        class="page-img"
      />
    </div>
  </div>
</Layout>

<style>
  .page-content {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 0;
  }

  .image-wrap {
    flex: 1;
    min-height: 0;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .page-img {
    display: block;
    height: 100%;
    max-height: 100%;
    width: auto;
    max-width: 100%;
    object-fit: contain;
  }
</style>
